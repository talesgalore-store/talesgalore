<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Character Match — TalesGalore Literary Games</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root{--cream:#FDFAF4;--warm:#F5EDD8;--gold:#C8923A;--gold-lt:#E8B96A;--ink:#8B5E3C;--muted:#7A6A52;--rule:#E2D5BC;--dark:#3D2B0E;--success:#4A7C59;--danger:#B03030;--blue:#1A3A5C}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--cream);font-family:'Lato',sans-serif;color:var(--dark);min-height:100vh}
.tg-header{background:var(--ink);padding:16px 28px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 10px rgba(61,43,14,.2)}
.badge{background:var(--gold);color:#fff;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:3px 8px;border-radius:3px}
.tg-header h1{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#fff}
.tg-header h1 span{color:var(--gold-lt)}
.tg-header a.back{margin-left:auto;color:var(--rule);text-decoration:none;font-size:13px}
.tg-header a.back:hover{color:var(--gold-lt)}

.game-wrap{max-width:860px;margin:0 auto;padding:36px 20px 60px}

.start-screen{text-align:center;padding:36px 0}
.game-icon{font-size:70px;display:block;margin-bottom:18px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
.start-screen h2{font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:var(--dark);margin-bottom:12px}
.start-screen p{color:var(--muted);font-size:16px;line-height:1.7;max-width:440px;margin:0 auto 26px}
.rules{background:var(--warm);border:1.5px solid var(--rule);border-radius:12px;padding:18px 22px;text-align:left;margin-bottom:26px}
.rules h4{font-family:'Playfair Display',serif;font-size:15px;color:var(--dark);margin-bottom:8px}
.rules li{color:var(--muted);font-size:14px;margin-left:18px;margin-bottom:5px}
.btn-primary{background:var(--gold);color:#fff;font-weight:700;font-size:16px;padding:13px 34px;border:none;border-radius:10px;cursor:pointer;transition:background .2s,transform .15s}
.btn-primary:hover{background:#a8762e;transform:scale(1.03)}

.progress-info{display:flex;justify-content:space-between;font-size:13px;color:var(--muted);margin-bottom:6px}
.progress-bar{background:var(--rule);border-radius:10px;height:7px;margin-bottom:22px;overflow:hidden}
.progress-fill{background:linear-gradient(90deg,#1A3A5C,#2E86C1);height:100%;border-radius:10px;transition:width .4s}

.match-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.col-header{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:10px;text-align:center}

.match-item{
  background:#fff;border:2px solid var(--rule);border-radius:12px;
  padding:14px 16px;cursor:pointer;text-align:center;
  transition:border-color .2s,background .2s,transform .15s;
  font-size:14px;line-height:1.4;min-height:58px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Lato',sans-serif;color:var(--dark);
}
.match-item:hover:not(.matched):not(.wrong-flash){border-color:var(--blue);background:var(--warm);transform:scale(1.02)}
.match-item.selected{border-color:var(--blue);background:#EAF0F8;transform:scale(1.02)}
.match-item.matched{border-color:var(--success)!important;background:#EAF4EE!important;cursor:default;color:var(--success);font-weight:700}
.match-item.wrong-flash{border-color:var(--danger)!important;background:#FDECEA!important;animation:shake .4s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}

.char-icon{font-size:22px;display:block;margin-bottom:4px}

.score-bar{
  background:var(--warm);border:1.5px solid var(--rule);border-radius:12px;
  padding:14px 20px;display:flex;justify-content:space-between;align-items:center;
  margin-bottom:20px;flex-wrap:wrap;gap:10px;
}
.score-bar .stat{text-align:center}
.score-bar .stat .n{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--dark);display:block;line-height:1}
.score-bar .stat .l{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px}

.feedback-strip{
  padding:12px 18px;border-radius:10px;font-size:14px;margin-bottom:16px;
  display:none;line-height:1.5;text-align:center;
}
.feedback-strip.show{display:block}
.feedback-strip.correct-fb{background:#EAF4EE;border:1.5px solid var(--success);color:#2E6645}
.feedback-strip.wrong-fb{background:#FDECEA;border:1.5px solid var(--danger);color:#8B2020}

.score-screen{text-align:center;padding:20px 0}
.score-circle{width:130px;height:130px;border-radius:50%;background:var(--warm);border:4px solid var(--blue);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 22px;font-family:'Playfair Display',serif}
.score-circle .big{font-size:38px;font-weight:700;color:var(--dark);line-height:1}
.score-circle .out{font-size:14px;color:var(--muted)}
.score-screen h2{font-family:'Playfair Display',serif;font-size:28px;color:var(--dark);margin-bottom:10px}
.score-screen p{color:var(--muted);font-size:15px;max-width:420px;margin:0 auto 26px;line-height:1.7}
.btn-secondary{background:transparent;border:2px solid var(--gold);color:var(--gold);font-weight:700;font-size:14px;padding:10px 22px;border-radius:8px;cursor:pointer;margin:0 6px;transition:all .2s}
.btn-secondary:hover{background:var(--gold);color:#fff}
.tg-footer{background:var(--dark);color:var(--rule);text-align:center;padding:26px 20px;font-size:13px}
.tg-footer em{color:var(--gold);font-style:italic;font-family:'Playfair Display',serif;display:block;margin-bottom:5px}
@media(max-width:560px){.match-grid{grid-template-columns:1fr}.game-wrap{padding:22px 14px 48px}}
</style>
</head>
<body>
<header class="tg-header">
  <span class="badge">Games</span>
  <h1>Tales<span>Galore</span></h1>
  <a class="back" href="literary-games.html">← All Games</a>
</header>

<div class="game-wrap">
  <div id="startScreen" class="start-screen">
    <span class="game-icon">🔗</span>
    <h2>Character Match</h2>
    <p>Click a character on the left, then click their book on the right to make a match. How quickly can you pair them all up?</p>
    <div class="rules">
      <h4>📋 How to play</h4>
      <ul>
        <li>Click a character card to select it (it'll turn blue)</li>
        <li>Then click the matching book title</li>
        <li>Correct pairs turn green and stay matched</li>
        <li>Wrong pairs flash red — try again!</li>
        <li>No time limit — take your time!</li>
      </ul>
    </div>
    <button class="btn-primary" onclick="startGame()">Start Matching →</button>
  </div>

  <div id="gameScreen" style="display:none">
    <div class="progress-info">
      <span>Match all 10 pairs</span>
      <span id="matchCount">0 / 10 matched</span>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>

    <div class="score-bar">
      <div class="stat"><span class="n" id="matchedNum" style="color:var(--success)">0</span><div class="l">Matched</div></div>
      <div class="stat"><span class="n" id="attemptsNum">0</span><div class="l">Attempts</div></div>
      <div class="stat"><span class="n" id="wrongNum" style="color:var(--danger)">0</span><div class="l">Wrong</div></div>
    </div>

    <div class="feedback-strip" id="feedbackStrip"></div>

    <div class="match-grid">
      <div>
        <div class="col-header">🧒 Characters</div>
        <div id="charCol" style="display:flex;flex-direction:column;gap:10px"></div>
      </div>
      <div>
        <div class="col-header">📚 Books</div>
        <div id="bookCol" style="display:flex;flex-direction:column;gap:10px"></div>
      </div>
    </div>
  </div>

  <div id="scoreScreen" style="display:none" class="score-screen">
    <div class="score-circle">
      <span class="big" id="finalAttempts">0</span>
      <span class="out">tries</span>
    </div>
    <h2 id="resultTitle">All matched!</h2>
    <p id="resultMsg"></p>
    <button class="btn-primary" onclick="restartGame()">Play Again</button>
    <button class="btn-secondary" onclick="location.href='literary-games.html'">All Games</button>
  </div>
</div>

<footer class="tg-footer">
  <em>— TalesGalore Literary Games —</em>
  Stories worth rediscovering
</footer>

<script>
const pairs=[
  {char:"🐛 The Very Hungry Caterpillar",icon:"🐛",book:"The Very Hungry Caterpillar"},
  {char:"🦁 Aslan",icon:"🦁",book:"The Lion, the Witch and the Wardrobe"},
  {char:"🐻 Paddington",icon:"🐻",book:"A Bear Called Paddington"},
  {char:"🧙 Matilda",icon:"🧙",book:"Matilda"},
  {char:"🐷 Wilbur",icon:"🐷",book:"Charlotte's Web"},
  {char:"🪄 James",icon:"🪄",book:"James and the Giant Peach"},
  {char:"🐰 Peter Rabbit",icon:"🐰",book:"The Tale of Peter Rabbit"},
  {char:"🌊 Kiki",icon:"🌊",book:"Kiki's Delivery Service"},
  {char:"🦊 Mr Fox",icon:"🦊",book:"Fantastic Mr Fox"},
  {char:"🐺 Max",icon:"🐺",book:"Where the Wild Things Are"},
];

let selectedChar=null,matched=0,attempts=0,wrongCount=0;
let shuffledChars=[],shuffledBooks=[];

function shuffle(a){return [...a].sort(()=>Math.random()-.5)}

function startGame(){
  document.getElementById('startScreen').style.display='none';
  document.getElementById('gameScreen').style.display='block';
  matched=0;attempts=0;wrongCount=0;selectedChar=null;
  shuffledChars=shuffle(pairs.map((_,i)=>i));
  shuffledBooks=shuffle(pairs.map((_,i)=>i));
  renderCards();
}

function renderCards(){
  const charCol=document.getElementById('charCol');
  const bookCol=document.getElementById('bookCol');
  charCol.innerHTML='';
  bookCol.innerHTML='';

  shuffledChars.forEach(idx=>{
    const d=document.createElement('div');
    d.className='match-item';
    d.dataset.idx=idx;
    d.dataset.type='char';
    d.innerHTML=`<span class="char-icon">${pairs[idx].icon}</span>${pairs[idx].char.replace(pairs[idx].icon+' ','')}`;
    d.onclick=()=>selectChar(idx,d);
    charCol.appendChild(d);
  });

  shuffledBooks.forEach(idx=>{
    const d=document.createElement('div');
    d.className='match-item';
    d.dataset.idx=idx;
    d.dataset.type='book';
    d.innerHTML=`📖 ${pairs[idx].book}`;
    d.onclick=()=>selectBook(idx,d);
    bookCol.appendChild(d);
  });
}

function selectChar(idx,el){
  if(el.classList.contains('matched')) return;
  document.querySelectorAll('[data-type="char"]').forEach(e=>e.classList.remove('selected'));
  el.classList.add('selected');
  selectedChar=idx;
  showFeedback('Click the matching book on the right!','');
}

function selectBook(idx,el){
  if(el.classList.contains('matched')) return;
  if(selectedChar===null){showFeedback('First select a character on the left.','wrong');return;}
  attempts++;
  document.getElementById('attemptsNum').textContent=attempts;

  if(idx===selectedChar){
    // Correct!
    matched++;
    // Mark both
    document.querySelectorAll('[data-type="char"]').forEach(e=>{
      if(parseInt(e.dataset.idx)===selectedChar){
        e.classList.remove('selected');
        e.classList.add('matched');
        e.onclick=null;
      }
    });
    el.classList.add('matched');
    el.onclick=null;
    selectedChar=null;
    document.getElementById('matchedNum').textContent=matched;
    document.getElementById('matchCount').textContent=`${matched} / ${pairs.length} matched`;
    document.getElementById('progressFill').style.width=`${(matched/pairs.length)*100}%`;
    showFeedback(`✅ Correct! ${pairs[idx].char} belongs to "${pairs[idx].book}"!`,'correct');
    if(matched===pairs.length) setTimeout(showResult,800);
  } else {
    wrongCount++;
    document.getElementById('wrongNum').textContent=wrongCount;
    // Flash red
    const charEl=document.querySelector(`[data-type="char"][data-idx="${selectedChar}"]`);
    if(charEl){charEl.classList.add('wrong-flash');setTimeout(()=>charEl.classList.remove('wrong-flash'),500);}
    el.classList.add('wrong-flash');
    setTimeout(()=>el.classList.remove('wrong-flash'),500);
    showFeedback(`❌ Not quite — try a different book for that character!`,'wrong');
  }
}

function showFeedback(msg,type){
  const el=document.getElementById('feedbackStrip');
  el.textContent=msg;
  el.className='feedback-strip show'+(type==='correct'?' correct-fb':type==='wrong'?' wrong-fb':'');
}

function showResult(){
  document.getElementById('gameScreen').style.display='none';
  document.getElementById('scoreScreen').style.display='block';
  document.getElementById('finalAttempts').textContent=attempts;
  let title,msg;
  if(attempts<=10){title='🏆 Perfect Matching!';msg='10 pairs matched in just '+attempts+' attempts — flawless!';}
  else if(attempts<=14){title='⭐ Sharp Mind!';msg='All matched in '+attempts+' attempts. Very impressive character knowledge!';}
  else if(attempts<=18){title='📚 Well Done!';msg='You got there! '+attempts+' attempts total. A few tricky ones in there!';}
  else{title='🌱 All Matched!';msg=attempts+' attempts — persistence wins the day! Try again to beat your score!'}
  document.getElementById('resultTitle').textContent=title;
  document.getElementById('resultMsg').textContent=msg;
}

function restartGame(){
  document.getElementById('scoreScreen').style.display='none';
  document.getElementById('gameScreen').style.display='block';
  matched=0;attempts=0;wrongCount=0;selectedChar=null;
  shuffledChars=shuffle(pairs.map((_,i)=>i));
  shuffledBooks=shuffle(pairs.map((_,i)=>i));
  document.getElementById('matchedNum').textContent=0;
  document.getElementById('attemptsNum').textContent=0;
  document.getElementById('wrongNum').textContent=0;
  document.getElementById('matchCount').textContent='0 / 10 matched';
  document.getElementById('progressFill').style.width='0%';
  document.getElementById('feedbackStrip').className='feedback-strip';
  renderCards();
}
</script>
</body>
</html>
