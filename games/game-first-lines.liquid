<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>First Lines — TalesGalore Literary Games</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root{--cream:#FDFAF4;--warm:#F5EDD8;--gold:#C8923A;--gold-lt:#E8B96A;--ink:#8B5E3C;--muted:#7A6A52;--rule:#E2D5BC;--dark:#3D2B0E;--success:#4A7C59;--danger:#B03030;--red:#6B2737}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--cream);font-family:'Lato',sans-serif;color:var(--dark);min-height:100vh}
.tg-header{background:var(--ink);padding:16px 28px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 10px rgba(61,43,14,.2)}
.badge{background:var(--gold);color:#fff;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:3px 8px;border-radius:3px}
.tg-header h1{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#fff}
.tg-header h1 span{color:var(--gold-lt)}
.tg-header a.back{margin-left:auto;color:var(--rule);text-decoration:none;font-size:13px}
.tg-header a.back:hover{color:var(--gold-lt)}

.game-wrap{max-width:680px;margin:0 auto;padding:36px 20px 60px}

.start-screen{text-align:center;padding:36px 0}
.game-icon{font-size:70px;display:block;margin-bottom:18px;animation:flip 3s ease-in-out infinite}
@keyframes flip{0%,100%{transform:rotateY(0deg)}50%{transform:rotateY(180deg)}}
.start-screen h2{font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:var(--dark);margin-bottom:12px}
.start-screen p{color:var(--muted);font-size:16px;line-height:1.7;max-width:440px;margin:0 auto 26px}
.rules{background:var(--warm);border:1.5px solid var(--rule);border-radius:12px;padding:18px 22px;text-align:left;margin-bottom:26px}
.rules h4{font-family:'Playfair Display',serif;font-size:15px;color:var(--dark);margin-bottom:8px}
.rules li{color:var(--muted);font-size:14px;margin-left:18px;margin-bottom:5px}
.btn-primary{background:var(--red);color:#fff;font-weight:700;font-size:16px;padding:13px 34px;border:none;border-radius:10px;cursor:pointer;transition:background .2s,transform .15s}
.btn-primary:hover{background:#8B2020;transform:scale(1.03)}

.progress-info{display:flex;justify-content:space-between;font-size:13px;color:var(--muted);margin-bottom:6px}
.progress-bar{background:var(--rule);border-radius:10px;height:7px;margin-bottom:20px;overflow:hidden}
.progress-fill{background:linear-gradient(90deg,var(--red),#C0392B);height:100%;border-radius:10px;transition:width .4s}
.timer-row{display:flex;align-items:center;gap:10px;margin-bottom:22px}
.timer-track{flex:1;background:var(--rule);border-radius:10px;height:10px;overflow:hidden}
.timer-fill{height:100%;border-radius:10px;background:var(--success);transition:width 1s linear,background .5s}

/* QUOTE CARD */
.quote-card{
  background:var(--warm);
  border:1.5px solid var(--rule);
  border-left:5px solid var(--gold);
  border-radius:12px;
  padding:28px 28px 24px;
  margin-bottom:24px;
  position:relative;
}
.quote-card::before{
  content:'"';
  position:absolute;top:8px;left:14px;
  font-family:'Playfair Display',serif;
  font-size:64px;color:var(--gold-lt);line-height:1;
  opacity:.5;
}
.q-num{font-size:11px;font-weight:700;letter-spacing:1.5px;color:var(--red);text-transform:uppercase;margin-bottom:12px}
.quote-text{
  font-family:'Playfair Display',serif;
  font-size:19px;font-style:italic;
  color:var(--dark);line-height:1.7;
  padding-left:24px;
}

.options{display:flex;flex-direction:column;gap:10px;margin-top:20px}
.option{
  background:#fff;border:2px solid var(--rule);border-radius:10px;
  padding:13px 18px;cursor:pointer;font-size:15px;color:var(--dark);
  text-align:left;font-family:'Lato',sans-serif;
  transition:border-color .15s,background .15s;
  display:flex;align-items:center;gap:12px;
}
.option:hover:not(:disabled){border-color:var(--red);background:var(--warm)}
.opt-letter{min-width:28px;height:28px;border-radius:50%;background:var(--rule);color:var(--muted);font-weight:700;font-size:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.option.correct{background:#EAF4EE!important;border-color:var(--success)!important;color:var(--success)}
.option.correct .opt-letter{background:var(--success);color:#fff}
.option.wrong{background:#FDECEA!important;border-color:var(--danger)!important;color:var(--danger)}
.option.wrong .opt-letter{background:var(--danger);color:#fff}
.option:disabled{cursor:default}

.feedback{padding:12px 16px;border-radius:10px;font-size:14px;margin-top:14px;display:none;line-height:1.6}
.feedback.show{display:block}
.feedback.correct-fb{background:#EAF4EE;border:1.5px solid var(--success);color:#2E6645}
.feedback.wrong-fb{background:#FDECEA;border:1.5px solid var(--danger);color:#8B2020}
.next-btn{display:none;background:var(--red);color:#fff;font-weight:700;font-size:14px;padding:11px 26px;border:none;border-radius:8px;cursor:pointer;margin-top:12px;transition:background .2s}
.next-btn.show{display:inline-block}
.next-btn:hover{background:#8B2020}

.score-screen{text-align:center;padding:20px 0}
.score-circle{width:130px;height:130px;border-radius:50%;background:var(--warm);border:4px solid var(--red);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 22px;font-family:'Playfair Display',serif}
.score-circle .big{font-size:38px;font-weight:700;color:var(--dark);line-height:1}
.score-circle .out{font-size:14px;color:var(--muted)}
.score-screen h2{font-family:'Playfair Display',serif;font-size:28px;color:var(--dark);margin-bottom:10px}
.score-screen p{color:var(--muted);font-size:15px;max-width:420px;margin:0 auto 26px;line-height:1.7}
.btn-secondary{background:transparent;border:2px solid var(--gold);color:var(--gold);font-weight:700;font-size:14px;padding:10px 22px;border-radius:8px;cursor:pointer;margin:0 6px;transition:all .2s}
.btn-secondary:hover{background:var(--gold);color:#fff}
.tg-footer{background:var(--dark);color:var(--rule);text-align:center;padding:26px 20px;font-size:13px}
.tg-footer em{color:var(--gold);font-style:italic;font-family:'Playfair Display',serif;display:block;margin-bottom:5px}
@media(max-width:500px){.game-wrap{padding:22px 14px 48px}.quote-text{font-size:16px}}
</style>
</head>
<body>
<header class="tg-header">
  <span class="badge">Games</span>
  <h1>Tales<span>Galore</span></h1>
  <a class="back" href="literary-games.html">← All Games</a>
</header>

<div class="game-wrap">
  <div id="startScreen" class="start-screen">
    <span class="game-icon">📖</span>
    <h2>First Lines</h2>
    <p>Every great story begins with a single unforgettable sentence. Read the opening line and guess which famous children's book it belongs to!</p>
    <div class="rules">
      <h4>📋 How to play</h4>
      <ul>
        <li>Read the famous opening line carefully</li>
        <li>Choose the correct book from 4 options</li>
        <li>25 seconds per question</li>
        <li>8 first lines to identify in total</li>
      </ul>
    </div>
    <button class="btn-primary" onclick="startGame()">Start Reading →</button>
  </div>

  <div id="gameScreen" style="display:none">
    <div class="progress-info">
      <span id="qLabel">Line 1 of 8</span>
      <span id="scoreLabel">Score: 0</span>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>
    <div class="timer-row">
      <span>⏱</span>
      <div class="timer-track"><div class="timer-fill" id="timerFill" style="width:100%"></div></div>
      <span id="timerNum" style="font-weight:700;font-size:14px;min-width:26px;text-align:right">25</span>
    </div>

    <div class="quote-card">
      <div class="q-num" id="qNum">Line 1</div>
      <div class="quote-text" id="quoteText"></div>
    </div>

    <div class="options" id="optionsGrid"></div>
    <div class="feedback" id="feedback"></div>
    <button class="next-btn" id="nextBtn" onclick="nextQuestion()">Next Line →</button>
  </div>

  <div id="scoreScreen" style="display:none" class="score-screen">
    <div class="score-circle">
      <span class="big" id="finalScore">0</span>
      <span class="out">/ 8</span>
    </div>
    <h2 id="resultTitle">Well read!</h2>
    <p id="resultMsg"></p>
    <button class="btn-primary" onclick="restartGame()">Play Again</button>
    <button class="btn-secondary" onclick="location.href='literary-games.html'">All Games</button>
  </div>
</div>

<footer class="tg-footer">
  <em>— TalesGalore Literary Games —</em>
  Stories worth rediscovering
</footer>

<script>
const lines=[
  {
    line:"There is a place called Far-Far-Away, and in it there lived a donkey called Shrek.",
    ans:"Shrek!",
    opts:["Shrek!","Donkey Kong","The Faraway Tree","The Enormous Turnip"],
    explain:"This is the opening of William Steig's original 1990 picture book, long before the film! Most people don't know the book exists."
  },
  {
    line:"The night Max wore his wolf suit and made mischief of one kind and another, his mother called him WILD THING!",
    ans:"Where the Wild Things Are",
    opts:["Where the Wild Things Are","The Gruffalo","Room on the Broom","Varjak Paw"],
    explain:"Maurice Sendak's 1963 masterpiece begins here. Max is sent to his room without supper and imagination takes over!"
  },
  {
    line:"Once upon a time, four little Rabbits, and their names were Flopsy, Mopsy, Cotton-tail, and Peter.",
    ans:"The Tale of Peter Rabbit",
    opts:["The Velveteen Rabbit","The Tale of Peter Rabbit","Watership Down","The Wind in the Willows"],
    explain:"Beatrix Potter's beloved 1902 story. Peter, of course, immediately disobeys his mother and sneaks into Mr McGregor's garden!"
  },
  {
    line:"It was a bright cold day in April, and the clocks were striking thirteen.",
    ans:"Nineteen Eighty-Four",
    opts:["A Wrinkle in Time","The Giver","Nineteen Eighty-Four","The Maze Runner"],
    explain:"Technically a classic for older readers — George Orwell's 1984. That opening 'thirteen' immediately tells you this world is wrong."
  },
  {
    line:"Mr. and Mrs. Dursley, of number four, Privet Drive, were proud to say that they were perfectly normal, thank you very much.",
    ans:"Harry Potter and the Philosopher's Stone",
    opts:["Harry Potter and the Philosopher's Stone","The BFG","Roald Dahl's Book of Ghost Stories","The Witches"],
    explain:"J.K. Rowling's iconic 1997 opening sets up the Dursleys perfectly — their desperate normality is what makes Harry's magical world so glorious in contrast."
  },
  {
    line:"Here is Edward Bear, coming downstairs now, bump, bump, bump, on the back of his head, behind Christopher Robin.",
    ans:"Winnie-the-Pooh",
    opts:["Paddington Bear","Winnie-the-Pooh","The Teddy Bears' Picnic","Rupert Bear"],
    explain:"A.A. Milne's 1926 classic begins with that wonderful bumping descent — immediately establishing Pooh's loveable, gentle nature."
  },
  {
    line:"The year I turned twelve, my father decided to take me out of school and let me have the run of his library.",
    ans:"The Name of This Book Is Secret",
    opts:["Matilda","The Name of This Book Is Secret","Inkheart","The Books of Beginning"],
    explain:"Pseudonymous Bosch's 2007 mystery-comedy. The unnamed narrator's adventure begins the moment they discover that library."
  },
  {
    line:"My name is Mary Katherine Blackwood. I am eighteen years old, and I live with my sister Constance.",
    ans:"We Have Always Lived in the Castle",
    opts:["A Little Princess","We Have Always Lived in the Castle","Rebecca","Jane Eyre"],
    explain:"Shirley Jackson's darkly brilliant 1962 novel. Merricat's voice is unforgettable from the very first line."
  },
];

let current=0,score=0,timer=null,timeLeft=25;

function startGame(){
  document.getElementById('startScreen').style.display='none';
  document.getElementById('gameScreen').style.display='block';
  showQuestion();
}

function showQuestion(){
  const q=lines[current];
  document.getElementById('qLabel').textContent=`Line ${current+1} of ${lines.length}`;
  document.getElementById('scoreLabel').textContent=`Score: ${score}`;
  document.getElementById('progressFill').style.width=`${(current/lines.length)*100}%`;
  document.getElementById('qNum').textContent=`Line ${current+1}`;
  document.getElementById('quoteText').textContent=q.line;
  document.getElementById('feedback').className='feedback';
  document.getElementById('nextBtn').className='next-btn';

  const shuffled=[...q.opts].sort(()=>Math.random()-.5);
  const grid=document.getElementById('optionsGrid');
  const letters=['A','B','C','D'];
  grid.innerHTML='';
  shuffled.forEach((o,i)=>{
    const btn=document.createElement('button');
    btn.className='option';
    btn.innerHTML=`<span class="opt-letter">${letters[i]}</span>${o}`;
    btn.onclick=()=>answer(o===q.ans,btn,q.ans,shuffled);
    grid.appendChild(btn);
  });

  timeLeft=25;
  clearInterval(timer);
  updateTimerUI();
  timer=setInterval(()=>{
    timeLeft--;
    updateTimerUI();
    if(timeLeft<=0){clearInterval(timer);timeOut();}
  },1000);
}

function answer(isCorrect,btn,correctAns,shuffled){
  clearInterval(timer);
  document.querySelectorAll('.option').forEach(b=>b.disabled=true);
  const fb=document.getElementById('feedback');
  if(isCorrect){
    btn.classList.add('correct');
    score++;
    fb.textContent=`✅ Correct! ${lines[current].explain}`;
    fb.className='feedback show correct-fb';
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('.option').forEach(b=>{
      if(b.textContent.includes(correctAns)) b.classList.add('correct');
    });
    fb.textContent=`❌ The answer was "${correctAns}". ${lines[current].explain}`;
    fb.className='feedback show wrong-fb';
  }
  document.getElementById('scoreLabel').textContent=`Score: ${score}`;
  document.getElementById('nextBtn').className='next-btn show';
}

function timeOut(){
  document.querySelectorAll('.option').forEach(b=>{
    b.disabled=true;
    if(b.textContent.includes(lines[current].ans)) b.classList.add('correct');
  });
  const fb=document.getElementById('feedback');
  fb.textContent=`⏰ Time's up! The answer was "${lines[current].ans}".`;
  fb.className='feedback show wrong-fb';
  document.getElementById('nextBtn').className='next-btn show';
}

function updateTimerUI(){
  const pct=(timeLeft/25)*100;
  const fill=document.getElementById('timerFill');
  fill.style.width=pct+'%';
  fill.style.background=timeLeft>12?'#4A7C59':timeLeft>6?'var(--gold)':'var(--danger)';
  document.getElementById('timerNum').textContent=timeLeft;
}

function nextQuestion(){
  current++;
  if(current>=lines.length) showResult();
  else showQuestion();
}

function showResult(){
  document.getElementById('gameScreen').style.display='none';
  document.getElementById('scoreScreen').style.display='block';
  document.getElementById('finalScore').textContent=score;
  const pct=score/lines.length;
  let title,msg;
  if(pct===1){title='🏆 Literary Genius!';msg='A perfect score — every first line identified! You are a true lover of books in every sense.';}
  else if(pct>=.75){title='⭐ Brilliant Reader!';msg='Excellent work! You have a remarkable memory for the opening words of great books.';}
  else if(pct>=.5){title='📚 Well Read!';msg='A good score! Those first lines are tricky — more reading adventures await you at TalesGalore!';}
  else{title='🌱 Just Getting Started!';msg='First lines are famously hard! Every book you read from now on will feel like finding an old friend.';}
  document.getElementById('resultTitle').textContent=title;
  document.getElementById('resultMsg').textContent=msg;
}

function restartGame(){
  current=0;score=0;
  document.getElementById('scoreScreen').style.display='none';
  document.getElementById('gameScreen').style.display='block';
  showQuestion();
}
</script>
</body>
</html>
