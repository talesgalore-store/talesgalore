<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Book Quiz — TalesGalore Literary Games</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root{--cream:#FDFAF4;--warm:#F5EDD8;--gold:#C8923A;--gold-lt:#E8B96A;--ink:#8B5E3C;--muted:#7A6A52;--rule:#E2D5BC;--dark:#3D2B0E;--success:#4A7C59;--danger:#B03030}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--cream);font-family:'Lato',sans-serif;color:var(--dark);min-height:100vh}
.tg-header{background:var(--ink);padding:16px 28px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 10px rgba(61,43,14,.2)}
.badge{background:var(--gold);color:#fff;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:3px 8px;border-radius:3px}
.tg-header h1{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#fff}
.tg-header h1 span{color:var(--gold-lt)}
.tg-header a.back{margin-left:auto;color:var(--rule);text-decoration:none;font-size:13px;display:flex;align-items:center;gap:6px}
.tg-header a.back:hover{color:var(--gold-lt)}

.game-wrap{max-width:700px;margin:0 auto;padding:40px 20px 60px}

/* START SCREEN */
.start-screen{text-align:center;padding:40px 20px}
.game-icon{font-size:72px;margin-bottom:20px;display:block;animation:bounce 2s infinite}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.start-screen h2{font-family:'Playfair Display',serif;font-size:34px;font-weight:700;color:var(--dark);margin-bottom:12px}
.start-screen p{color:var(--muted);font-size:16px;line-height:1.7;max-width:460px;margin:0 auto 30px}
.rules{background:var(--warm);border:1.5px solid var(--rule);border-radius:12px;padding:20px 24px;text-align:left;margin-bottom:30px}
.rules h4{font-family:'Playfair Display',serif;font-size:15px;color:var(--dark);margin-bottom:10px}
.rules li{color:var(--muted);font-size:14px;margin-left:18px;margin-bottom:6px;line-height:1.5}
.btn-primary{background:var(--gold);color:#fff;font-family:'Lato',sans-serif;font-weight:700;font-size:16px;padding:14px 36px;border:none;border-radius:10px;cursor:pointer;transition:background .2s,transform .15s;display:inline-block}
.btn-primary:hover{background:#a8762e;transform:scale(1.03)}

/* PROGRESS BAR */
.progress-bar{background:var(--rule);border-radius:10px;height:8px;margin-bottom:28px;overflow:hidden}
.progress-fill{background:linear-gradient(90deg,var(--gold),var(--gold-lt));height:100%;border-radius:10px;transition:width .4s ease}
.progress-info{display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px;color:var(--muted)}
.timer-bar{display:flex;align-items:center;gap:10px;margin-bottom:24px}
.timer-icon{font-size:18px}
.timer-track{flex:1;background:var(--rule);border-radius:10px;height:10px;overflow:hidden}
.timer-fill{height:100%;border-radius:10px;transition:width 1s linear,background .5s}

/* QUESTION CARD */
.question-card{background:#fff;border:1.5px solid var(--rule);border-radius:16px;padding:32px;margin-bottom:24px;box-shadow:0 4px 20px rgba(139,94,60,.07)}
.q-number{font-size:11px;font-weight:700;letter-spacing:1.5px;color:var(--gold);text-transform:uppercase;margin-bottom:10px}
.q-text{font-family:'Playfair Display',serif;font-size:20px;font-weight:600;color:var(--dark);line-height:1.5;margin-bottom:6px}
.q-hint{font-size:13px;color:var(--muted);font-style:italic;margin-bottom:0}

/* OPTIONS */
.options{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px}
.option{
  background:var(--warm);border:2px solid var(--rule);border-radius:10px;
  padding:14px 16px;cursor:pointer;font-size:15px;color:var(--dark);
  text-align:left;font-family:'Lato',sans-serif;line-height:1.4;
  transition:border-color .15s,background .15s,transform .1s;
  display:flex;align-items:center;gap:10px;
}
.option:hover:not(:disabled){border-color:var(--gold);background:#fff;transform:scale(1.01)}
.option .opt-letter{min-width:26px;height:26px;border-radius:50%;background:var(--rule);color:var(--muted);font-weight:700;font-size:12px;display:flex;align-items:center;justify-content:center}
.option.correct{background:#EAF4EE!important;border-color:var(--success)!important;color:var(--success)}
.option.correct .opt-letter{background:var(--success);color:#fff}
.option.wrong{background:#FDECEA!important;border-color:var(--danger)!important;color:var(--danger)}
.option.wrong .opt-letter{background:var(--danger);color:#fff}
.option:disabled{cursor:default}

/* FEEDBACK */
.feedback{padding:14px 18px;border-radius:10px;font-size:14px;margin-top:16px;display:none;line-height:1.6}
.feedback.show{display:block}
.feedback.correct-fb{background:#EAF4EE;border:1.5px solid var(--success);color:#2E6645}
.feedback.wrong-fb{background:#FDECEA;border:1.5px solid var(--danger);color:#8B2020}
.next-btn{background:var(--gold);color:#fff;font-weight:700;font-size:14px;padding:11px 28px;border:none;border-radius:8px;cursor:pointer;margin-top:16px;display:none;transition:background .2s}
.next-btn.show{display:inline-block}
.next-btn:hover{background:#a8762e}

/* SCORE SCREEN */
.score-screen{text-align:center;padding:20px 0}
.score-circle{width:130px;height:130px;border-radius:50%;background:var(--warm);border:4px solid var(--gold);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 24px;font-family:'Playfair Display',serif}
.score-circle .big{font-size:40px;font-weight:700;color:var(--dark);line-height:1}
.score-circle .out{font-size:14px;color:var(--muted)}
.score-screen h2{font-family:'Playfair Display',serif;font-size:28px;color:var(--dark);margin-bottom:10px}
.score-screen p{color:var(--muted);font-size:15px;max-width:420px;margin:0 auto 28px;line-height:1.7}
.btn-secondary{background:transparent;border:2px solid var(--gold);color:var(--gold);font-weight:700;font-size:14px;padding:11px 24px;border-radius:8px;cursor:pointer;margin:0 8px;transition:all .2s}
.btn-secondary:hover{background:var(--gold);color:#fff}
.tally{display:flex;justify-content:center;gap:16px;margin-bottom:24px;flex-wrap:wrap}
.tally-box{background:#fff;border:1.5px solid var(--rule);border-radius:10px;padding:12px 20px;text-align:center;min-width:90px}
.tally-box .n{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;display:block}
.tally-box .n.g{color:var(--success)}.tally-box .n.r{color:var(--danger)}
.tally-box .l{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px}

.tg-footer{background:var(--dark);color:var(--rule);text-align:center;padding:28px 20px;font-size:13px}
.tg-footer em{color:var(--gold);font-style:italic;font-family:'Playfair Display',serif;font-size:14px;display:block;margin-bottom:5px}
@media(max-width:500px){.options{grid-template-columns:1fr}.game-wrap{padding:28px 16px 48px}}
</style>
</head>
<body>

<header class="tg-header">
  <span class="badge">Games</span>
  <h1>Tales<span>Galore</span></h1>
  <a class="back" href="literary-games.html">← All Games</a>
</header>

<div class="game-wrap">

  <!-- START -->
  <div id="startScreen" class="start-screen">
    <span class="game-icon">🎯</span>
    <h2>Children's Book Quiz</h2>
    <p>Think you know your children's books? Ten questions, ten chances to prove it. From beloved classics to modern gems!</p>
    <div class="rules">
      <h4>📋 How to play</h4>
      <ul>
        <li>10 multiple-choice questions</li>
        <li>20 seconds per question — choose wisely!</li>
        <li>Each correct answer earns 10 points</li>
        <li>Bonus points for answering quickly</li>
      </ul>
    </div>
    <button class="btn-primary" onclick="startGame()">Start Quiz →</button>
  </div>

  <!-- QUIZ -->
  <div id="quizScreen" style="display:none">
    <div class="progress-info">
      <span id="qLabel">Question 1 of 10</span>
      <span id="scoreLabel">Score: 0</span>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>

    <div class="timer-bar">
      <span class="timer-icon">⏱</span>
      <div class="timer-track"><div class="timer-fill" id="timerFill" style="width:100%;background:var(--success)"></div></div>
      <span id="timerNum" style="font-weight:700;font-size:14px;min-width:28px;text-align:right">20</span>
    </div>

    <div class="question-card">
      <div class="q-number" id="qNum">Question 1</div>
      <div class="q-text" id="qText"></div>
      <div class="q-hint" id="qHint"></div>
      <div class="options" id="optionsGrid"></div>
      <div class="feedback" id="feedback"></div>
      <button class="next-btn" id="nextBtn" onclick="nextQuestion()">Next Question →</button>
    </div>
  </div>

  <!-- RESULT -->
  <div id="scoreScreen" style="display:none" class="score-screen">
    <div class="score-circle">
      <span class="big" id="finalScore">0</span>
      <span class="out">/ 100</span>
    </div>
    <h2 id="resultTitle">Well done!</h2>
    <p id="resultMsg"></p>
    <div class="tally">
      <div class="tally-box"><span class="n g" id="correctCount">0</span><div class="l">Correct</div></div>
      <div class="tally-box"><span class="n r" id="wrongCount">0</span><div class="l">Wrong</div></div>
      <div class="tally-box"><span class="n" id="bonusCount" style="color:var(--gold)">0</span><div class="l">Bonus Pts</div></div>
    </div>
    <button class="btn-primary" onclick="restartGame()">Play Again</button>
    <button class="btn-secondary" onclick="location.href='literary-games.html'">All Games</button>
  </div>

</div>

<footer class="tg-footer">
  <em>— TalesGalore Literary Games —</em>
  Stories worth rediscovering
</footer>

<script>
const questions = [
  {q:"Who wrote 'Charlie and the Chocolate Factory'?",hint:"A much-loved British author of children's stories",opts:["Roald Dahl","C.S. Lewis","Enid Blyton","A.A. Milne"],ans:0,explain:"Roald Dahl wrote this beloved classic in 1964. The story follows young Charlie Bucket's golden-ticket adventure."},
  {q:"What is the name of the friendly giant in Roald Dahl's book?",hint:"He appears to Sophie in her orphanage bedroom",opts:["The BFG","The BGF","The GBF","The FBG"],ans:0,explain:"The BFG stands for Big Friendly Giant — written in 1982 and later adapted into a Steven Spielberg film."},
  {q:"In 'The Gruffalo', where does the mouse go for a walk?",hint:"Think dark and filled with trees...",opts:["The deep dark wood","The enchanted forest","The meadow","The riverbank"],ans:0,explain:"The mouse takes a stroll through the deep dark wood — bravely tricking the fox, owl, and snake with tales of the Gruffalo!"},
  {q:"What colour is the Very Hungry Caterpillar's body?",hint:"He has a red head",opts:["Green","Blue","Red","Yellow"],ans:0,explain:"Eric Carle's caterpillar has a bright green body with a red head. Published in 1969, it's one of the world's best-selling picture books."},
  {q:"Which animal befriends the tiger in 'The Tiger Who Came to Tea'?",hint:"She watches while Mummy makes tea",opts:["Sophie","Lily","Alice","Rosie"],ans:0,explain:"Sophie and her mother welcome the tiger who eats all their food and drinks all their drink in this 1968 classic by Judith Kerr."},
  {q:"What is Matilda's special power in Roald Dahl's 'Matilda'?",hint:"She can move objects with her mind",opts:["Telekinesis","Invisibility","Flying","Mind reading"],ans:0,explain:"Matilda discovers she has telekinesis — the ability to move objects with her mind — which she uses brilliantly against the horrible Miss Trunchbull."},
  {q:"Who created the character Paddington Bear?",hint:"The bear comes from darkest Peru",opts:["Michael Bond","Roald Dahl","A.A. Milne","Lewis Carroll"],ans:0,explain:"Michael Bond created Paddington Bear in 1958, inspired by a toy bear he saw on a shelf at Paddington Station on Christmas Eve."},
  {q:"In the 'Harry Potter' series, what is Harry's owl called?",hint:"She is a snowy white owl",opts:["Hedwig","Errol","Pigwidgeon","Crookshanks"],ans:0,explain:"Hedwig is Harry's loyal snowy owl, given to him as a birthday gift by Hagrid in Diagon Alley."},
  {q:"What sound does the Gruffalo have?",hint:"It matches his terrible tusks",opts:["Terrible roar","Terrible growl","Terrible bark","Terrible howl"],ans:0,explain:"The Gruffalo has terrible tusks and terrible claws, terrible teeth in his terrible jaws — and a terrible roar!"},
  {q:"In 'Winnie the Pooh', what is Eeyore?",hint:"He is always rather gloomy",opts:["A donkey","A horse","A mule","A pony"],ans:0,explain:"Eeyore is A.A. Milne's loveable, perpetually gloomy donkey who lives in the Hundred Acre Wood. He first appeared in 1926."},
];

let current=0,score=0,correct=0,wrong=0,bonus=0,timer=null,timeLeft=20;
let shuffled=[];

function shuffleArr(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

function startGame(){
  document.getElementById('startScreen').style.display='none';
  document.getElementById('quizScreen').style.display='block';
  showQuestion();
}

function showQuestion(){
  const q=questions[current];
  document.getElementById('qLabel').textContent=`Question ${current+1} of ${questions.length}`;
  document.getElementById('scoreLabel').textContent=`Score: ${score}`;
  document.getElementById('progressFill').style.width=`${(current/questions.length)*100}%`;
  document.getElementById('qNum').textContent=`Question ${current+1}`;
  document.getElementById('qText').textContent=q.q;
  document.getElementById('qHint').textContent=`💡 Hint: ${q.hint}`;
  document.getElementById('feedback').className='feedback';
  document.getElementById('feedback').textContent='';
  document.getElementById('nextBtn').className='next-btn';

  const correctText=q.opts[q.ans];
  shuffled=shuffleArr(q.opts);

  const grid=document.getElementById('optionsGrid');
  const letters=['A','B','C','D'];
  grid.innerHTML='';
  shuffled.forEach((o,i)=>{
    const btn=document.createElement('button');
    btn.className='option';
    btn.innerHTML=`<span class="opt-letter">${letters[i]}</span>${o}`;
    btn.onclick=()=>answer(o===correctText,btn,correctText);
    grid.appendChild(btn);
  });

  timeLeft=20;
  startTimer();
}

function startTimer(){
  clearInterval(timer);
  updateTimerUI();
  timer=setInterval(()=>{
    timeLeft--;
    updateTimerUI();
    if(timeLeft<=0){clearInterval(timer);timeOut();}
  },1000);
}

function updateTimerUI(){
  const pct=(timeLeft/20)*100;
  const fill=document.getElementById('timerFill');
  fill.style.width=pct+'%';
  fill.style.background=timeLeft>10?'#4A7C59':timeLeft>5?'var(--gold)':'var(--danger)';
  document.getElementById('timerNum').textContent=timeLeft;
}

function answer(isCorrect,btn,correctText){
  clearInterval(timer);
  const q=questions[current];
  const btns=document.querySelectorAll('.option');
  btns.forEach(b=>b.disabled=true);
  const fb=document.getElementById('feedback');

  if(isCorrect){
    btn.classList.add('correct');
    const b=Math.round((timeLeft/20)*10);
    score+=10+b; correct++; bonus+=b;
    fb.textContent=`✅ Correct! +${10+b} points (${b} speed bonus). ${q.explain}`;
    fb.className='feedback show correct-fb';
  } else {
    btn.classList.add('wrong');
    btns.forEach(b=>{if(b.textContent.includes(correctText)) b.classList.add('correct');});
    wrong++;
    fb.textContent=`❌ Not quite. ${q.explain}`;
    fb.className='feedback show wrong-fb';
  }
  document.getElementById('scoreLabel').textContent=`Score: ${score}`;
  document.getElementById('nextBtn').className='next-btn show';
}

function timeOut(){
  const q=questions[current];
  const correctText=q.opts[q.ans];
  const btns=document.querySelectorAll('.option');
  btns.forEach(b=>{
    b.disabled=true;
    if(b.textContent.includes(correctText)) b.classList.add('correct');
  });
  wrong++;
  const fb=document.getElementById('feedback');
  fb.textContent=`⏰ Time's up! The answer was: ${correctText}. ${q.explain}`;
  fb.className='feedback show wrong-fb';
  document.getElementById('nextBtn').className='next-btn show';
}

function nextQuestion(){
  current++;
  if(current>=questions.length){showResult();}
  else{showQuestion();}
}

function showResult(){
  document.getElementById('quizScreen').style.display='none';
  document.getElementById('scoreScreen').style.display='block';
  document.getElementById('finalScore').textContent=score;
  document.getElementById('correctCount').textContent=correct;
  document.getElementById('wrongCount').textContent=wrong;
  document.getElementById('bonusCount').textContent=bonus;
  const pct=score/100;
  let title,msg;
  if(pct>=0.9){title='🏆 Bookworm Supreme!';msg="Outstanding! You clearly spend a lot of time surrounded by wonderful books. TalesGalore salutes you!";}
  else if(pct>=0.7){title='⭐ Brilliant Reader!';msg="Really impressive! You know your children's classics very well. A few more visits to TalesGalore and you'll be unstoppable!";}
  else if(pct>=0.5){title='📚 Good Effort!';msg="A solid performance! The world of children's books is vast and wonderful — keep exploring and you'll ace it next time.";}
  else{title='🌱 Keep Reading!';msg="Every reader starts somewhere! The best thing about not knowing is that you get to discover these amazing books for the first time.";}
  document.getElementById('resultTitle').textContent=title;
  document.getElementById('resultMsg').textContent=msg;
}

function restartGame(){
  current=0;score=0;correct=0;wrong=0;bonus=0;
  document.getElementById('scoreScreen').style.display='none';
  document.getElementById('quizScreen').style.display='block';
  showQuestion();
}
</script>
</body>
</html>
